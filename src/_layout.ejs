<!DOCTYPE html>
<html lang="ru">
  <% 
  function getRootPath(){
    if(process.cwd()+"\\src\\"+current.source+".ejs"==__filename)
    { 
      return ""; 
    }
    else 
    {  
      return "../"; 
    }
  }
  function getLangRootPath(lang){
    let arr = ["skincare","face_massage","lash_and_brow_lifting","microneedling","social_media_marketing"];
    if(arr.includes(current.source))
    { 
      return "../"+lang+"/training/"+current.source+".html"; 
    }
    else 
    {  
      return "../"+lang+"/"+current.source+".html"; 
    }
  }
  %>
